# Copier vers `.env` ou `.env.local` (non versionné).

# --- CoinGecko (évite les 429 de l’API publique sans clé) ---
# Clé gratuite « Demo » : https://www.coingecko.com/en/api
# En `npm run dev`, le proxy Vite ajoute l’en-tête automatiquement (clé hors du bundle).
VITE_COINGECKO_DEMO_API_KEY=

# Plan Pro (optionnel) : mêmes règles ; le proxy cible pro-api.coingecko.com
# VITE_COINGECKO_PRO_API_KEY=

# Backend / proxy perso (prod recommandé pour ne pas publier la clé dans le JS)
# Doit exposer le chemin équivalent à /api/v3 de CoinGecko.
# VITE_COINGECKO_API_ROOT=https://votre-serveur.com/coingecko
#
# Délai max des fetch RPC / CoinGecko / api.rayls.com (ms), entre 5000 et 120000. Défaut 28000.
# VITE_FETCH_TIMEOUT_MS=28000
#
# Si vous imposez une CSP : si VITE_COINGECKO_API_ROOT, VITE_RAYLS_RPC_HTTP_URL ou VITE_RPC_WS_URL
# pointent vers un autre hôte, ajoutez ce domaine dans connect-src (wss: pour WebSocket).

# --- RPC JSON-RPC depuis le navigateur (CORS) ---
# Sur *.github.io le RPC Rayls bloque le navigateur (pas de CORS). GitHub Pages : une fois le workflow
# « Deploy RPC CORS proxy » (Cloudflare) exécuté, la variable de dépôt VITE_RAYLS_RPC_HTTP_URL est remplie.
# En local / surcharge :
# VITE_RAYLS_RPC_HTTP_URL=https://votre-worker.workers.dev
# GitHub Pages (workflow) : VITE_RPC_WS_URL=0 pour éviter soucis WebSocket depuis github.io

# Spot USD « exchange » (WebSocket public MEXC, paire RLS/USDT). En `npm run dev` : activé par défaut.
# Production / désactiver en local : VITE_MEXC_SPOT_WS=0
# Forcer explicite en prod : VITE_MEXC_SPOT_WS=1
# VITE_MEXC_SYMBOL=RLSUSDT
# VITE_MEXC_WS_URL=wss://wbs-api.mexc.com/ws

# Cadence spot CoinGecko (ms), min 5000. Défaut 10000. Avec clé demo : ex. 5000–8000 (garder ≤ ou proche du gap ci‑dessous).
# VITE_LIVE_SPOT_MS=10000

# Écart minimal entre deux appels réseau simple/price (ms), min 3000. Défaut 7000 (doit rester ≤ à VITE_LIVE_SPOT_MS pour chaque tick utile).
# VITE_CG_QUOTE_MIN_GAP_MS=7000

# Écart minimal entre deux appels market_chart / ohlc CoinGecko (ms), min 3000. Défaut 6000 (réactivité des périodes) ; augmentez (12000–20000) si 429.
# VITE_CG_CHART_MIN_GAP_MS=6000

# Pause supplémentaire (ms) avant chaque requête OHLC, après l’écart ci‑dessus — limite les 429 quand on enchaîne courbe + bougies sans clé. Défaut 4500 ; mettre 0 pour désactiver.
# VITE_CG_OHLC_EXTRA_GAP_MS=4500

# Polling batch RPC HTTP (ms), min 300. Défaut 1000.
# VITE_RPC_POLL_MS=1000

# WebSocket JSON-RPC : défaut wss://mainnet-rpc.rayls.com — désactiver : 0 | false | off
# VITE_RPC_WS_URL=

# Hub supplies Rayls (ms), min 15000. Défaut 60000.
# VITE_OFFICIAL_HUB_POLL_MS=60000

# Flux JSON « Actualités » : par défaut l’app charge /rayls-feed.json (fichier dans public/).
# Surcharge HTTPS ou autre chemin racine : VITE_RAYLS_PUBLIC_FEED_URL=https://…/feed.json
# Désactiver le flux automatique : VITE_RAYLS_PUBLIC_FEED_URL=off
# VITE_RAYLS_PUBLIC_FEED_URL=
# Rafraîchissement du flux (ms), min 1_800_000 (30 min). Défaut 6 h (21_600_000).
# VITE_NEWS_REFRESH_MS=21600000
