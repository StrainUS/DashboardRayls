{
  "name": "rayls-network-monitor",
  "private": true,
  "version": "1.0.0",
  "description": "Operational dashboard for Rayls mainnet RPC health, CoinGecko market data, and public Rayls APIs (unofficial, informational).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/StrainUS/DashboardRayls.git"
  },
  "bugs": {
    "url": "https://github.com/StrainUS/DashboardRayls/issues"
  },
  "homepage": "https://strainus.github.io/DashboardRayls/",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base /DashboardRayls/",
    "lint": "eslint .",
    "verify:feed": "node scripts/validate-rayls-feed.mjs",
    "favicons:from-logo": "node scripts/gen-favicons-from-logo.mjs",
    "test": "vitest run",
    "ci": "npm run lint && npm run test && npm run verify:feed && npm run build",
    "audit:ci": "npm audit --audit-level=moderate",
    "typecheck": "tsc -b --pretty",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
